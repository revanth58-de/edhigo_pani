# ══════════════════════════════════════════════════════════
#  Edhigo Pani — Backend Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit the actual .env file to git.
# ══════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development     # "development" | "production"

# ── Database ─────────────────────────────────────────────
# Development (SQLite — single machine only):
DATABASE_URL="file:./prisma/dev.db"

# Production (PostgreSQL — required for deployment):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# Example (Neon.tech):
# DATABASE_URL="postgresql://neondb_owner:abc123@ep-quiet-pond-123.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── JWT Secrets ───────────────────────────────────────────
# IMPORTANT: Generate strong random secrets before deployment.
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── OTP ───────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=5

# ── Admin Panel ───────────────────────────────────────────
# Use a strong password — this protects the admin dashboard
ADMIN_SECRET=REPLACE_WITH_STRONG_ADMIN_PASSWORD

# ── SMS (Fast2SMS) ────────────────────────────────────────
# Get your key from https://fast2sms.com/dashboard/keys
FAST2SMS_API_KEY=YOUR_FAST2SMS_API_KEY_HERE

# ── CORS ──────────────────────────────────────────────────
# In production, set this to your exact domain (no trailing slash)
# e.g. ALLOWED_ORIGIN=https://your-app.com
# In development, leave as * or http://localhost:3000
ALLOWED_ORIGIN=*

# ── Features ──────────────────────────────────────────────
# Set to "true" to enforce GPS proximity for QR attendance (100m radius)
# Set to "false" during testing/demo
GEOFENCE_ENABLED=false

# ── Cloudinary (Photo Uploads) — Optional but recommended in production ──
# Get keys from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_API_KEY
CLOUDINARY_API_SECRET=YOUR_API_SECRET
