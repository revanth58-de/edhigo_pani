# ─── DINASARI Backend — Production Environment Variables ───────────────────
#
# Copy this file to .env and fill in all values before deploying.
# NEVER commit your real .env to git.
#
# Generate strong secrets:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
#   or: openssl rand -base64 64

# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
# Use PostgreSQL in production — NOT SQLite!
# I3 FIX: Add connection pool params for Neon.tech to prevent connection exhaustion.
#   connection_limit=10  → max 10 simultaneous DB connections (Neon free tier safe)
#   pool_timeout=20      → fail fast after 20s if no connection is free
# Example: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public&connection_limit=10&pool_timeout=20
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/dinasari?schema=public&connection_limit=10&pool_timeout=20"

# SQLite for local development only:
# DATABASE_URL="file:./prisma/dev.db"

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# MUST be changed — use long, random, unique strings for each secret
JWT_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET_64_CHARS_MIN"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_STRONG_RANDOM_SECRET_64_CHARS_MIN"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# ── OTP ──────────────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=5

# ── Admin Panel ───────────────────────────────────────────────────────────────
# ADMIN_SECRET: The password used to obtain an admin JWT. Change this!
ADMIN_SECRET="REPLACE_WITH_STRONG_ADMIN_PASSWORD"
# ADMIN_JWT_SECRET: Signs the short-lived admin JWT tokens (2h TTL).
# Falls back to JWT_SECRET if not set, but a dedicated secret is recommended.
ADMIN_JWT_SECRET="REPLACE_WITH_ANOTHER_STRONG_64_CHAR_RANDOM_STRING"

# ── SMS (Fast2SMS) ────────────────────────────────────────────────────────────
# Get your API key from https://fast2sms.com
FAST2SMS_API_KEY="YOUR_FAST2SMS_API_KEY_HERE"

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set to your frontend domain or * for open access (not recommended for production)
ALLOWED_ORIGIN="https://your-app.com"

# ── Geofencing ────────────────────────────────────────────────────────────────
# Set to true to enforce 100m radius check-in/check-out
GEOFENCE_ENABLED=true
